# SQLite (local dev, no MySQL needed)
DATABASE_URL=sqlite:///./sparkle.db

# MySQL (production)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/sparkle_db
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
OTP_EXPIRE_MINUTES=5
OTP_DEV_MODE=true
OTP_RATE_LIMIT_PER_MINUTE=3

# SMS OTP (set to receive OTP on real mobile)
# SMS_PROVIDER=none        # Development: OTP shown on screen only
# SMS_PROVIDER=fast2sms    # India: get API key from https://www.fast2sms.com
# SMS_PROVIDER=twilio      # International: https://www.twilio.com

SMS_PROVIDER=none
FAST2SMS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
